{
  "name": "repair-app-monorepo",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "api",
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "host:start": "npm run start -w apps/host",
    "host:build": "npm run build -w apps/host",
    "host:typecheck": "npm run typecheck -w apps/host",
    "admin:start": "npm run start -w apps/admin",
    "admin:build": "npm run build -w apps/admin",
    "admin:typecheck": "npm run typecheck -w apps/admin",
    "api:start": "npm run start -w api",
    "api:build": "npm run build -w api",
    "dev": "concurrently \"npm run api:start\" \"npm run host:start\" \"npm run admin:start\"",
    "build": "npm run api:build && npm run host:build && npm run admin:build",
    "typecheck": "npm run host:typecheck && npm run admin:typecheck"
  },
  "devDependencies": {
    "concurrently": "^10.0.0"
  }
}
